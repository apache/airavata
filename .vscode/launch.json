{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Serve Airavata",
      "request": "launch",
      "mainClass": "org.apache.airavata.AiravataCommandLine",
      "projectName": "distribution",
      "args": "serve",
      "cwd": "${workspaceFolder}",
      "vmArgs": "-Dairavata.home=${workspaceFolder}/modules/distribution/target/classes -Dairavata.config.dir=${workspaceFolder}/modules/distribution/target/classes/conf",
      "env": { "AIRAVATA_HOME": "${workspaceFolder}/modules/distribution/target/classes" }
    },
    {
      "type": "java",
      "name": "Serve Airavata (Debug)",
      "request": "launch",
      "mainClass": "org.apache.airavata.AiravataCommandLine",
      "projectName": "distribution",
      "args": "serve",
      "cwd": "${workspaceFolder}",
      "vmArgs": "-Dairavata.home=${workspaceFolder}/modules/distribution/target/classes -Dairavata.config.dir=${workspaceFolder}/modules/distribution/target/classes/conf -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005",
      "env": { "AIRAVATA_HOME": "${workspaceFolder}/modules/distribution/target/classes" }
    }
  ]
}
