<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d [%t] %-5p %c{30} %X - %m%n" />
    </Console>
    <RollingFile name="RollingFileAppender" fileName="../logs/airavata-api.log"
      filePattern="../logs/airavata-api-%d{MM-dd-yyyy}-%i.log.gz">
      <PatternLayout>
        <Pattern>%d [%t] %-5p %c{30} %X - %m%n</Pattern>
      </PatternLayout>
      <Policies>
        <OnStartupTriggeringPolicy />
        <TimeBasedTriggeringPolicy />
        <SizeBasedTriggeringPolicy size="50 MB" />
      </Policies>
      <DefaultRolloverStrategy max="20" />
    </RollingFile>
  </Appenders>
  <Loggers>
    <!-- Suppress verbose logging from third-party libraries -->
    <logger name="ch.qos.logback" level="WARN" />
    <logger name="org.apache.helix" level="WARN" />
    <logger name="org.apache.zookeeper" level="ERROR" />
    <logger name="org.hibernate" level="ERROR" />
    <logger name="org.hibernate.orm" level="ERROR" />
    <logger name="org.springframework" level="WARN" />
    <logger name="org.springframework.boot" level="WARN" />
    <logger name="org.springframework.context" level="WARN" />
    <logger name="org.springframework.test" level="WARN" />
    <logger name="org.springframework.data" level="WARN" />
    <logger name="org.springframework.orm" level="WARN" />
    <logger name="org.springframework.transaction" level="WARN" />
    <logger name="com.zaxxer.hikari" level="WARN" />
    <logger name="org.apache.kafka" level="WARN" />
    <logger name="org.apache.curator" level="WARN" />
    <!-- Airavata packages - only show WARN and above during tests -->
    <logger name="org.apache.airavata" level="WARN" />
    <!-- Keep test framework logs at INFO for test results visibility -->
    <logger name="org.junit" level="INFO" />
    <logger name="org.junit.jupiter" level="INFO" />
    <logger name="org.junit.platform" level="INFO" />
    <Root level="WARN">
      <AppenderRef ref="Console" />
      <AppenderRef ref="RollingFileAppender" />
    </Root>
  </Loggers>
</Configuration>