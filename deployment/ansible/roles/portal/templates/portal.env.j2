# {{ ansible_managed }}
# Next.js portal environment configuration
# Generated by Ansible — do not edit manually

# API backend
NEXT_PUBLIC_API_URL={{ portal_api_url }}
API_URL={{ portal_api_url }}

# NextAuth configuration
NEXTAUTH_URL={{ portal_nextauth_url }}
NEXTAUTH_SECRET={{ portal_nextauth_secret }}

# Keycloak / OIDC configuration
KEYCLOAK_ISSUER={{ portal_keycloak_issuer }}
KEYCLOAK_CLIENT_ID={{ portal_keycloak_client_id }}
{% if portal_keycloak_client_secret != "" %}
KEYCLOAK_CLIENT_SECRET={{ portal_keycloak_client_secret }}
{% endif %}

# Portal runtime
NODE_ENV=production
PORT={{ portal_port }}
HOSTNAME=0.0.0.0
