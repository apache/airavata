# {{ansible_managed}}

# Database
db=mysql
db-url-host={{ keycloak_db_host }}
db-url-port={{ keycloak_db_port }}
db-url-database={{ keycloak_db_schema_name }}
db-username={{ keycloak_db_username }}
db-password={{ keycloak_db_password }}
db-pool-min-size={{ keycloak_db_pool_size }}
db-pool-max-size={{ keycloak_db_pool_size }}

# HTTP
http-port=8080
http-relative-path=/

# HTTPS (if using reverse proxy with SSL termination)
# https-port=8443
# https-relative-path=/

# Admin credentials (set via environment variables in systemd service)
# KEYCLOAK_ADMIN={{ keycloak_master_account_username }}
# KEYCLOAK_ADMIN_PASSWORD={{ keycloak_master_account_password }}

# Hostname
hostname={{ keycloak_vhost_servername }}
hostname-strict=false
hostname-strict-https=false

# Proxy settings (if behind reverse proxy)
proxy=edge
http-relative-path=/
